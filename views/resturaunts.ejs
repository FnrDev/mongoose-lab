<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <ul>
        <% for(let resturaunt of resturaunts) { %>
            <li>Name: <%= resturaunt.name %></li>
            <li>Address: <%= resturaunt.address %></li>
            <li>Phone: <%= resturaunt.phone %></li>
            <li>Is open: <%= resturaunt.isOpen %></li>
        <% } %>
    </ul>
</body>
</html>